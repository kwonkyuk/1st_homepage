rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Fields: id, title, category, description, imageUrl, client, date
    //
    // Collection: signage
    // Fields: id, title, imageUrl
    //
    // Collection: hero
    // Fields: id, imageUrl
    //
    // ===============================================================

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "kwonkyuk17@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProject(data) {
      return data.keys().hasAll(['id', 'title', 'category', 'description', 'imageUrl']) &&
             data.id is string && data.id.size() > 0 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.category in ['Sculpture', 'Facility', 'Space', 'Visual'] &&
             data.description is string && data.description.size() < 2000 &&
             data.imageUrl is string && data.imageUrl.size() < 2000000; // Allow large base64 for now, but should be careful
    }

    function isValidSignage(data) {
      return data.keys().hasAll(['id', 'title', 'imageUrl']) &&
             data.id is string &&
             data.title is string && data.title.size() < 200 &&
             data.imageUrl is string && data.imageUrl.size() < 2000000;
    }

    function isValidHero(data) {
      return data.keys().hasAll(['id', 'imageUrl']) &&
             data.id is string &&
             data.imageUrl is string && data.imageUrl.size() < 2000000;
    }

    // Rules
    match /projects/{projectId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProject(request.resource.data);
      allow delete: if isAdmin();
    }

    match /signage/{signageId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSignage(request.resource.data);
      allow delete: if isAdmin();
    }

    match /hero/{heroId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidHero(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
